# Base URL the built frontend calls for the API. Leave unset in local dev - the
# same-origin dev proxy (see vite.config.ts) forwards backend paths to VITE_DEV_API.
VITE_API_BASE=
VITE_API_BASE_URL=

# There is deliberately NO VITE_API_KEY: Vite inlines every VITE_* value into the built
# JS bundle, so a key set at build time would ship readable to every browser (SEC-06).
# The frontend no longer reads such a variable at all. Browser auth is the signed
# httponly session cookie (/auth/session, SHELFWISE_AUTH_MODE=jwt); server-to-server
# callers may supply x-api-key via the deployment-owned runtime config file
# (public/shelfwise-config.js), which never enters the bundle.

# Dev-server only: where the Vite proxy forwards backend requests, and which port the
# dev server itself listens on.
VITE_DEV_API=http://localhost:8000
PORT=5173
