# Base URL the built frontend calls for the API. Leave unset in local dev - the
# same-origin dev proxy (see vite.config.ts) forwards backend paths to VITE_DEV_API.
VITE_API_BASE=
VITE_API_BASE_URL=

# Do NOT put a real write-path API key here. Vite inlines every VITE_* value into the
# built JS bundle, so anything set here ships to every browser and is trivially
# readable - it provides no real access control. Authorize writes with the tenant JWT
# instead (SHELFWISE_AUTH_MODE=jwt on the backend); reserve API_KEY for
# server-to-server callers only.
VITE_API_KEY=

# Dev-server only: where the Vite proxy forwards backend requests, and which port the
# dev server itself listens on.
VITE_DEV_API=http://localhost:8000
PORT=5173
