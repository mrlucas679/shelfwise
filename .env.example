APP_NAME=ShelfWise
APP_ENV=local
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SHELFWISE_STORE_BACKEND=memory
SHELFWISE_BUS_BACKEND=memory
SHELFWISE_AUTH_MODE=off
SHELFWISE_TENANT_ID=sa_retail_demo
WORKER_ENABLED=false
# DATABASE_URL must point at the restricted shelfwise_app role (provisioned by
# src/shelfwise_storage/init_app_role.sh), never at POSTGRES_USER - a superuser/BYPASSRLS
# connection silently bypasses every tenant row-level-security policy this app relies on.
# These are local-development-only defaults; rotate before any shared/production use.
DATABASE_URL=postgresql://shelfwise_app:shelfwise_app_local_only@postgres:5432/shelfwise
POSTGRES_APP_PASSWORD=shelfwise_app_local_only
REDIS_URL=redis://redis:6379/0
TENANT_AUTH_SECRET=
# The write-path shared secret (see API_KEY below) and the request-body size cap.
API_KEY=
SHELFWISE_MAX_BODY_BYTES=6291456

# Inference is optional for the first smoke slice.
# Use both credit paths:
# - Fireworks AI for managed reliability and fast public-demo development.
# - AMD Developer Cloud MI300X/vLLM for the direct ROCm proof and benchmark recording.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_ROUTINE_MODEL=
LLM_STRONG_MODEL=
LLM_TIMEOUT_SECONDS=25
LLM_COMPUTE_RESOURCE=
LLM_ACCELERATOR=

# Voice and vision are optional. Routes stay disabled unless this is true.
MULTIMODAL_ENABLED=false
STT_BASE_URL=http://localhost:8000/v1
STT_MODEL=openai/whisper-large-v3-turbo
TTS_BASE_URL=http://localhost:8800
TTS_MODEL=kokoro
VLM_BASE_URL=http://localhost:8000/v1
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct
MULTIMODAL_TIMEOUT_S=30

# Cold-chain resilience demo feed - off unless explicitly enabled.
COLD_CHAIN_DEMO=false
COLD_CHAIN_DEMO_INTERVAL_S=2.0
COLD_CHAIN_DEMO_MINUTES=60

# Observability: estimated inference cost per 1,000 tokens, in ZAR.
INFERENCE_ZAR_PER_1K=0.004

# Alias accepted for SHELFWISE_TENANT_ID (either may be set).
TENANT_ID=

# Escape hatch for local Postgres debugging only - never set this outside a local
# throwaway database. See src/shelfwise_storage/postgres.py.
SHELFWISE_ALLOW_SUPERUSER_DB=false
