APP_NAME=ShelfWise
APP_ENV=local
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SHELFWISE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SHELFWISE_STORE_BACKEND=memory
SHELFWISE_BUS_BACKEND=memory
SHELFWISE_AUTH_MODE=off
SHELFWISE_TENANT_ID=sa_retail_demo
WORKER_ENABLED=false
SHELFWISE_WORKER_API_KEY=
# Background loop that automatically pulls the poll-based ERP/WMS connectors (Odoo/SAP/
# SYSPRO/Dynamics Business Central) on an interval instead of requiring a manual
# /connectors/{system}/intake call.
# Single-tenant only (polls SHELFWISE_TENANT_ID above) - a system is polled only when its
# full credential set below is present; leave a system's vars blank to skip it entirely.
CONNECTOR_POLL_ENABLED=false
SHELFWISE_CONNECTOR_ODOO_BASE_URL=
SHELFWISE_CONNECTOR_ODOO_DATABASE=
SHELFWISE_CONNECTOR_ODOO_UID=
SHELFWISE_CONNECTOR_ODOO_API_KEY=
SHELFWISE_CONNECTOR_SAP_BASE_URL=
SHELFWISE_CONNECTOR_SAP_TOKEN=
SHELFWISE_CONNECTOR_SYSPRO_BASE_URL=
SHELFWISE_CONNECTOR_SYSPRO_TOKEN=
# Full Business Central `items` collection URL for one company; OAuth bearer token; the
# configured location supplies warehouse grain because the standard item resource does not.
SHELFWISE_CONNECTOR_DYNAMICS_BASE_URL=
SHELFWISE_CONNECTOR_DYNAMICS_TOKEN=
SHELFWISE_CONNECTOR_DYNAMICS_LOCATION_ID=
# HITL review windows and role workload caps can be overridden per deployment.
SHELFWISE_SLA_HIGH_MINUTES=60
SHELFWISE_SLA_MEDIUM_MINUTES=240
SHELFWISE_SLA_LOW_MINUTES=1440
# DATABASE_URL must point at the restricted shelfwise_app role (provisioned by
# src/shelfwise_storage/init_app_role.sh), never at POSTGRES_USER - a superuser/BYPASSRLS
# connection silently bypasses every tenant row-level-security policy this app relies on.
# These are local-development-only defaults; rotate before any shared/production use.
DATABASE_URL=postgresql://shelfwise_app:shelfwise_app_local_only@postgres:5432/shelfwise
# Required by docker-compose.production.yml's `postgres`/`migrate` services - the Postgres
# superuser (POSTGRES_USER=shelfwise) password used only to bootstrap the database and
# provision the restricted shelfwise_app role above. Compose fails fast if this is unset.
POSTGRES_PASSWORD=shelfwise_local_only
POSTGRES_APP_PASSWORD=shelfwise_app_local_only
REDIS_URL=redis://redis:6379/0
TENANT_AUTH_SECRET=
# The write-path shared secret (see API_KEY below) and the request-body size cap.
API_KEY=
SHELFWISE_MAX_BODY_BYTES=6291456
SHELFWISE_MAX_EVENT_AGE_SECONDS=31536000

# Disposable-cloud recovery root. Keep irreplaceable state here; use /scratch only for
# downloadable/rebuildable model and compiler caches on AMD droplets.
# SHELFWISE_PERSIST_ROOT=/workspace/persist
# TRAINING_OUTPUT_DIR=/workspace/persist/training
# HARNESS_RUN_DIR=/workspace/persist/harness/runs
# TRACE_DIR=/workspace/persist/runtime/agent-traces
# EVENT_STORE_DIR=/workspace/persist/runtime/events
# UPLOAD_DIR=/workspace/persist/application-data/uploads
# LOG_DIR=/workspace/persist/logs
# HF_HOME=/scratch/huggingface
# TORCH_HOME=/scratch/torch
# TRITON_CACHE_DIR=/scratch/triton
# TMPDIR=/scratch/tmp

# Inference is optional for the first smoke slice.
# Use both credit paths:
# - Fireworks AI for managed reliability and fast public-demo development.
# - AMD Developer Cloud MI300X/vLLM for the direct ROCm proof and benchmark recording.
LLM_BASE_URL=
# Provider identity is a deployment assertion, not inferred from a hostname. Leave blank for
# offline/default detection; set `vllm_mi300x` only for the verified AMD droplet, or `fireworks`
# for Fireworks. Any unknown OpenAI-compatible endpoint is labelled `openai_compatible` and cannot
# pass the AMD submission gate.
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_ROUTINE_MODEL=
LLM_STRONG_MODEL=
# Independent routine/strong endpoints for the two-tier MI300X topology (README's
# "Inference Strategy"). Each falls back to LLM_BASE_URL/LLM_API_KEY above when unset, so a
# single-endpoint deployment can leave these blank; set both to run genuinely separate
# routine and strong vLLM endpoints (dual_model_configured=true).
LLM_ROUTINE_BASE_URL=
LLM_ROUTINE_API_KEY=
LLM_STRONG_BASE_URL=
LLM_STRONG_API_KEY=
LLM_TIMEOUT_SECONDS=25
LLM_COMPUTE_RESOURCE=
LLM_ACCELERATOR=

# Voice and vision are optional. Routes stay disabled unless this is true. In production,
# enabling them requires SHELFWISE_AUTH_MODE=jwt; callers also pass the shared write guard.
MULTIMODAL_ENABLED=false
STT_BASE_URL=http://localhost:8000/v1
STT_MODEL=openai/whisper-large-v3-turbo
TTS_BASE_URL=http://localhost:8800
TTS_MODEL=kokoro
VLM_BASE_URL=http://localhost:8000/v1
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct
MULTIMODAL_TIMEOUT_S=30

# Cold-chain resilience demo feed - off unless explicitly enabled.
COLD_CHAIN_FEED_ENABLED=false
COLD_CHAIN_FEED_INTERVAL_S=2.0
COLD_CHAIN_FEED_MINUTES=60

# Observability: estimated inference cost per 1,000 tokens, in ZAR.
INFERENCE_ZAR_PER_1K=0.004

# Alias accepted for SHELFWISE_TENANT_ID (either may be set).
TENANT_ID=

# Escape hatch for local Postgres debugging only - never set this outside a local
# throwaway database. See src/shelfwise_storage/postgres.py.
SHELFWISE_ALLOW_SUPERUSER_DB=false

# Chat data boundary. Local defaults to the generated world; production defaults to
# the exact shop's reported digital twin. Never use world_simulation for a live store.
# SHELFWISE_CHAT_DATA_DOMAIN=operational_twin

# Let stores auto-create their own Postgres schema on first connect. Disable in any
# deployment that manages migrations explicitly instead.
# SHELFWISE_AUTO_SCHEMA=true

# Pooled Postgres connections (psycopg_pool) - the production default. Every checkout
# re-binds app.tenant_id session-level before handing the connection out, and the pool
# clears it again at check-in, so pooling never weakens RLS tenant isolation. Size
# SHELFWISE_DB_POOL_MAX below Postgres max_connections divided by backend replicas.
# SHELFWISE_DB_POOL=true
# SHELFWISE_DB_POOL_MIN=1
# SHELFWISE_DB_POOL_MAX=10

# How long a queued message may sit idle before the worker sweep presumes its consumer
# dead and reclaims it. DERIVED from SHELFWISE_REQUEST_TIMEOUT_SECONDS plus persistence
# margin (default 120s + 120s = 240s); this override can only RAISE it - values below
# the derived floor are clamped up, because a threshold inside the work budget steals
# live messages from healthy workers and double-runs them.
# SHELFWISE_WORKER_RECLAIM_IDLE_SECONDS=240

# Async twin projection worker (supplement to the idempotent inline ingest projection:
# crash recovery + multi-replica draining on its own Redis consumer group). Requires
# SHELFWISE_BUS_BACKEND=redis - it refuses the in-memory bus, which has no consumer
# groups; status is surfaced on /health as twin_projection_worker.
# TWIN_PROJECTION_WORKER_ENABLED=false

# Recurring governed schedules (twin fidelity revalidation). The revalidation loop
# recomputes every onboarded store's fidelity through the journaled plan runner and
# files a governed manager task when a score drifts below review threshold. Interval is
# daily by default with a 60s hot-loop floor; multi-week validation is this schedule
# left running. Status: GET /worker/schedules and /readiness.
# SCHEDULES_ENABLED=false
# TWIN_FIDELITY_REVALIDATION_SECONDS=86400

# Session cookie Secure flag. Must stay true for any non-local deployment; use
# SHELFWISE_ALLOW_INSECURE_COOKIE_IN_DISPOSABLE_CI below for the disposable-CI-only escape
# hatch instead of setting this false.
# SHELFWISE_COOKIE_SECURE=true

# Escape hatch allowing a non-Secure session cookie in a named (APP_ENV=production/staging)
# deployment. Only for disposable CI environments without HTTPS - never for a real deployment.
# SHELFWISE_ALLOW_INSECURE_COOKIE_IN_DISPOSABLE_CI=false

# Cap on the Redis event stream length per tenant (XTRIM bound). Leave unset for the
# built-in default.
# SHELFWISE_EVENT_STREAM_MAXLEN=

# Allow an unauthenticated caller to mint a same-origin demo browser session via
# POST /auth/session in jwt auth mode. Off by default; only for public demo deployments.
# SHELFWISE_PUBLIC_DEMO_SESSION=false

# Deployment request deadline in seconds. Defaults to 120 for real-app testing and is bounded
# only by the 15-minute operational safety maximum.
# SHELFWISE_REQUEST_TIMEOUT_SECONDS=

# Inference network deadline in seconds. Defaults to 120; set 29 only when checking the
# optional judge-facing 30-second target.
# LLM_TIMEOUT_SECONDS=

# Site identifier used by the standalone cold-chain resilience feed simulator
# (src/shelfwise_resilience) when no site_id is passed explicitly.
# SHELFWISE_SITE_ID=local-site

# Company-account login (/auth/login): owner credentials verified with stdlib scrypt.
# Generate the hash locally, never commit a real one:
#   python -c "import hashlib,os,getpass; s=os.urandom(16); print('scrypt$'+s.hex()+'$'+hashlib.scrypt(getpass.getpass().encode(),salt=s,n=16384,r=8,p=1).hex())"
# Unconfigured deployments answer 503 (never an open door).
# SHELFWISE_LOGIN_EMAIL=
# SHELFWISE_LOGIN_PASSWORD_HASH=
# SHELFWISE_LOGIN_SESSION_SECONDS=43200
