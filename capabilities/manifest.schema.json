{
  "$defs": {
    "AgentCapability": {
      "additionalProperties": false,
      "description": "A decision role declared by contracts or inference metadata.",
      "properties": {
        "agent_name": {
          "title": "Agent Name",
          "type": "string"
        },
        "id": {
          "pattern": "^[a-z_]+:.+",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "const": "agent",
          "default": "agent",
          "title": "Kind",
          "type": "string"
        },
        "metadata_only": {
          "default": false,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "relationships": {
          "items": {
            "$ref": "#/$defs/CapabilityRelationship"
          },
          "title": "Relationships",
          "type": "array"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/SourceLocation"
          },
          "minItems": 1,
          "title": "Sources",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/CapabilityStatus"
        },
        "verification_nodeids": {
          "items": {
            "type": "string"
          },
          "title": "Verification Nodeids",
          "type": "array"
        }
      },
      "required": [
        "id",
        "name",
        "status",
        "sources",
        "agent_name"
      ],
      "title": "AgentCapability",
      "type": "object"
    },
